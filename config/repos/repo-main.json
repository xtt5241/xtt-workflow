{
  "stack": "generic",
  "default_branch": "main",
  "install_cmd": "",
  "lint_cmd": "",
  "test_cmd": "python3 -m unittest discover -v",
  "build_cmd": "",
  "smoke_test_cmd": "python3 -m unittest -v",
  "targeted_test_cmd": "python3 -m unittest -v",
  "extended_test_cmd": "python3 -m unittest discover -v",
  "high_risk_paths": [],
  "forbidden_paths": [
    ".git",
    ".env",
    "secrets",
    "node_modules",
    "dist",
    "build"
  ],
  "needs_ui_evidence": false,
  "version": 2,
  "dependency_files": [],
  "lockfile_files": [],
  "environment_paths": [
    "env",
    "config/env",
    "config/runtime"
  ],
  "environment_files": [
    ".env.example",
    ".env.sample",
    "env.example",
    "env.sample"
  ],
  "runtime_files": [
    ".python-version",
    ".nvmrc",
    ".node-version",
    ".tool-versions",
    "runtime.txt"
  ],
  "package_manager_files": [
    "package.json",
    "pnpm-workspace.yaml",
    ".npmrc",
    ".yarnrc",
    ".yarnrc.yml"
  ],
  "tool_router": {
    "read_first": [
      "README.md",
      "manager/",
      "config/"
    ],
    "evidence_focus": [
      "structured result json"
    ],
    "by_type": {
      "build": {
        "execution_order": [
          "inspect-current-behavior",
          "patch-minimal-surface",
          "run-targeted-validation",
          "capture-structured-result"
        ]
      },
      "review": {
        "execution_order": [
          "inspect-real-diff",
          "read-risk-files",
          "report-findings-only"
        ]
      },
      "verify": {
        "execution_order": [
          "inspect-real-diff",
          "run-targeted-or-smoke-validation",
          "write-merge-decision-and-risks"
        ]
      }
    },
    "by_task_kind": {
      "infra": {
        "risk_focus": [
          "runtime / dependency / config drift"
        ]
      }
    }
  }
}
